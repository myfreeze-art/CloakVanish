<Window x:Class="CloakVanishApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CloakVanish Proxy Protocol" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Custom TextBox Style for Dark Theme -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="#252526"/>
                                <Setter Property="Foreground" Value="#909090"/>
                                <Setter Property="BorderBrush" Value="#2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Button Style with Hover/Click Animations -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0098FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Specific Green Action Button Style -->
        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#107C10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#179617"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0A520A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource AppTitle}" Foreground="#007ACC" FontSize="28" FontWeight="Black" LetterSpacing="2"/>
                <TextBlock Text="{DynamicResource Subtitle}" Foreground="#858585" FontSize="14" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <ComboBox x:Name="CboLanguage" Grid.Column="1" Width="120" Height="30" VerticalAlignment="Top" SelectionChanged="CboLanguage_SelectionChanged" Background="#2D2D30" Foreground="Black">
                <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                <ComboBoxItem Content="Русский" Tag="ru"/>
                <ComboBoxItem Content="Français" Tag="fr"/>
                <ComboBoxItem Content="Español" Tag="es"/>
                <ComboBoxItem Content="Deutsch" Tag="de"/>
                <ComboBoxItem Content="中文" Tag="zh"/>
                <ComboBoxItem Content="日本語" Tag="ja"/>
                <ComboBoxItem Content="한국어" Tag="ko"/>
                <ComboBoxItem Content="Italiano" Tag="it"/>
                <ComboBoxItem Content="Português" Tag="pt"/>
                <ComboBoxItem Content="العربية" Tag="ar"/>
                <ComboBoxItem Content="हिन्दी" Tag="hi"/>
                <ComboBoxItem Content="Türkçe" Tag="tr"/>
                <ComboBoxItem Content="Nederlands" Tag="nl"/>
                <ComboBoxItem Content="Polski" Tag="pl"/>
            </ComboBox>
        </Grid>

        <!-- Alias Generator -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnGenerateAlias" Grid.Column="0" Content="{DynamicResource BtnGenerateAlias}" Width="250" Height="45" Click="BtnGenerateAlias_Click"/>
            <TextBox x:Name="TxtAliasOutput" Grid.Column="1" IsReadOnly="True" Height="45" Margin="15,0,0,0"
                     Text="{DynamicResource AliasPlaceholder}" VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"/>
        </Grid>

        <!-- Tracker Neutralizer Input -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{DynamicResource HtmlInputLabel}" Foreground="#E0E0E0" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtHtmlInput" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Foreground="#D4D4D4"/>
        </Grid>

        <!-- Action Button -->
        <Button x:Name="BtnNeutralize" Grid.Row="3" Content="{DynamicResource BtnNeutralize}" Style="{StaticResource GreenButtonStyle}" Height="45" Margin="0,20,0,20" Click="BtnNeutralize_Click"/>

        <!-- Sanitized Output -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{DynamicResource HtmlOutputLabel}" Foreground="#107C10" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtHtmlOutput" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
        </Grid>

    </Grid>
</Window>
